#region ── Functions ──────────────────────────────────────────────────────────

function Add-FAQColumns {
    param([string]$ListName, [array]$Cols)

    foreach ($col in $Cols) {
        $existing = Get-PnPField -List $ListName -Identity $col.Name -ErrorAction SilentlyContinue
        if ($null -ne $existing) {
            Log-Warn "  Column already exists, skipping: $($col.Name)"
            continue
        }

        try {
            switch ($col.Type) {
                "Choice" {
                    # Build choice XML — safest cross-version approach for PnP
                    $choiceNodes = ($col.Choices | ForEach-Object { "<CHOICE>$_</CHOICE>" }) -join ""
                    $req = if ($col.Required) { "TRUE" } else { "FALSE" }
                    $xml = "<Field Type='Choice' Name='$($col.Name)' " +
                           "DisplayName='$($col.Name)' Required='$req'>" +
                           "<CHOICES>$choiceNodes</CHOICES></Field>"
                    Add-PnPFieldFromXml -List $ListName -FieldXml $xml | Out-Null
                }
                "Boolean" {
                    # Boolean via XML — Add-PnPField -Type Boolean is unreliable in some PnP builds
                    $req = if ($col.Required) { "TRUE" } else { "FALSE" }
                    $xml = "<Field Type='Boolean' Name='$($col.Name)' " +
                           "DisplayName='$($col.Name)' Required='$req'><Default>0</Default></Field>"
                    Add-PnPFieldFromXml -List $ListName -FieldXml $xml | Out-Null
                }
                "Note" {
                    Add-PnPField -List $ListName -DisplayName $col.Name `
                        -InternalName $col.Name -Type Note `
                        -Required:([bool]$col.Required) -ErrorAction Stop | Out-Null
                }
                "DateTime" {
                    Add-PnPField -List $ListName -DisplayName $col.Name `
                        -InternalName $col.Name -Type DateTime `
                        -Required:([bool]$col.Required) -ErrorAction Stop | Out-Null
                }
                "Number" {
                    Add-PnPField -List $ListName -DisplayName $col.Name `
                        -InternalName $col.Name -Type Number `
                        -Required:([bool]$col.Required) -ErrorAction Stop | Out-Null
                }
                default {
                    Add-PnPField -List $ListName -DisplayName $col.Name `
                        -InternalName $col.Name -Type Text `
                        -Required:([bool]$col.Required) -ErrorAction Stop | Out-Null
                }
            }
            Log-OK "  Column added: $($col.Name) [$($col.Type)]"
        }
        catch {
            Log-Err "  Column FAILED: $($col.Name) — $($_.Exception.Message)"
        }
    }
}


function New-FAQList {
    param([string]$ListName, [array]$Cols)

    Log-Info "Checking list: $ListName"

    $lst = Get-PnPList -Identity $ListName -ErrorAction SilentlyContinue
    if ($null -eq $lst) {
        try {
            New-PnPList -Title $ListName -Template GenericList -OnQuickLaunch:$false `
                        -ErrorAction Stop | Out-Null
            Log-OK "List created: $ListName"
        }
        catch {
            Log-Err "Could not create list '$ListName': $($_.Exception.Message)"
            return   # skip column work if list creation failed
        }
    }
    else {
        Log-Warn "List exists: $ListName — will only add missing columns"
    }

    Add-FAQColumns -ListName $ListName -Cols $Cols
}


function Add-ListItem {
    # Wraps Add-PnPListItem with a clear success/fail log
    param([string]$ListName, [hashtable]$Values)
    try {
        Add-PnPListItem -List $ListName -Values $Values -ErrorAction Stop | Out-Null
        Log-OK "Item added to $ListName : $($Values['Title'])"
    }
    catch {
        Log-Err "Item FAILED in $ListName : $($Values['Title']) — $($_.Exception.Message)"
    }
}

#endregion

