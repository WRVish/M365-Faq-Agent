# Step 4 — Insert smoke-test items
Log-Head "Step 4 — Insert Smoke-Test Records (2 per list)"
foreach ($lst in $Lists) {
    foreach ($item in $lst.Items) {
        Add-ListItem -ListName $lst.Name -Values $item
    }
}

# Done
