#region ── Main ───────────────────────────────────────────────────────────────

Log-Head "FAQ Hub — Provision & Smoke Test"
Write-Host "  Site    : $SiteUrl"
Write-Host "  Started : $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')"

# Step 1 — Connect
Log-Head "Step 1 — Connect to SharePoint"
try {
    Connect-PnPOnline -Url $SiteUrl -SPOManagementShell
    Log-OK "Connected to $SiteUrl"
}
catch {
    Log-Err "Connection failed: $($_.Exception.Message)"
    Log-Err "Make sure PnP.PowerShell is installed: Install-Module PnP.PowerShell -Scope CurrentUser"
    return   # use return not exit in ISE — exit closes the ISE host
}

# Step 2 — Provision FAQ lists
Log-Head "Step 2 — Provision FAQ Lists"
foreach ($lst in $Lists) {
    New-FAQList -ListName $lst.Name -Cols $lst.Cols
}

# Step 3 — Provision Analytics list
Log-Head "Step 3 — Provision Analytics List"
