#region ── Helpers ────────────────────────────────────────────────────────────

function Log-Head { param([string]$t)
    Write-Host "`n$('='*65)" -ForegroundColor Cyan
    Write-Host "  $t"        -ForegroundColor Cyan
    Write-Host "$('='*65)"   -ForegroundColor Cyan
}
function Log-OK   { param([string]$t) Write-Host "  [OK]   $t" -ForegroundColor Green  }
function Log-Warn { param([string]$t) Write-Host "  [WARN] $t" -ForegroundColor Yellow }
function Log-Err  { param([string]$t) Write-Host "  [ERR]  $t" -ForegroundColor Red    }
function Log-Info { param([string]$t) Write-Host "  [....] $t" -ForegroundColor White  }

#endregion

