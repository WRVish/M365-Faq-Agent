 <#
    FAQ Data Loader
    - Connects to SharePoint
    - Inserts 1 test record into FAQ_SharePoint, reads it back, deletes it
    - If test passes, loads all FAQ data into all lists
    SET $TestOnly = $true to just run the test without bulk load
#>

$SiteUrl     = "https://vishtechtalk.sharepoint.com/sites/DemoSite"
$Owner       = "admin@vishtechtalk.onmicrosoft.com"
$Reviewed    = "2026-05-07"
$TestOnly    = $false   # set to $true to only run the test record

Import-Module SharePointPnPPowerShellOnline -Force -WarningAction SilentlyContinue
Connect-PnPOnline -Url $SiteUrl -SPOManagementShell
Write-Host "Connected." -ForegroundColor Green

#region ── Helper ─────────────────────────────────────────────────────────────

function Add-Item {
    param([string]$List, [hashtable]$Val)
    try {
        Add-PnPListItem -List $List -Values $Val -ErrorAction Stop | Out-Null
        Write-Host "  [OK] $($Val.Title)" -ForegroundColor Green
    } catch {
        Write-Host "  [ERR] $($Val.Title) — $($_.Exception.Message)" -ForegroundColor Red
    }
}

function New-FAQ {
    param($Title,$Answer,$Product,$Category,$Audience,$Keywords,$Confidence=4)
    return @{
        Title        = $Title
        Answer       = $Answer
        Product      = $Product
        Category     = $Category
        Audience     = $Audience
        Keywords     = $Keywords
        Confidence   = $Confidence
        LastReviewed = $Reviewed
        Owner        = $Owner
        Tags         = ""
    }
}

#endregion

#region ── Test Record ────────────────────────────────────────────────────────

Write-Host "`n=== TEST: Insert, verify, delete ===" -ForegroundColor Cyan

$test = New-FAQ "TEST RECORD safe to delete" "Test answer." "SharePoint Online" "Setup" "End User" "test" 5
try {
    $item = Add-PnPListItem -List "FAQ_SharePoint" -Values $test -ErrorAction Stop
    Write-Host "  [OK] Inserted ID=$($item.Id)" -ForegroundColor Green
    $back = Get-PnPListItem -List "FAQ_SharePoint" -Id $item.Id
    Write-Host "  [OK] Read back: $($back.FieldValues['Title'])" -ForegroundColor Green
    Remove-PnPListItem -List "FAQ_SharePoint" -Identity $item.Id -Force
    Write-Host "  [OK] Deleted. TEST PASSED — proceeding to bulk load." -ForegroundColor Green
} catch {
    Write-Host "  [ERR] TEST FAILED: $($_.Exception.Message)" -ForegroundColor Red
    Write-Host "  Stopping. Fix the error above before loading data." -ForegroundColor Yellow
    return
}

if ($TestOnly) { Write-Host "TestOnly mode — done." -ForegroundColor Yellow; return }

#endregion

